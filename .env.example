# Configurações do WhatsApp MCP Remote
# Copie este arquivo para .env e preencha com seus dados

# Seu ID do WhatsApp (JID ou LID)
# Use o check_my_id.py para descobrir o seu
MY_WHATSAPP_JID=YOUR_PHONE_NUMBER@s.whatsapp.net

# Caminho para o log do bridge (opcional)
BRIDGE_LOG_PATH=whatsapp-bridge/bridge_log.txt

# Caminho para o banco de dados de mensagens (opcional)
WHATSAPP_DB_PATH=whatsapp-bridge/store/messages.db
